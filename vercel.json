{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/wedding/browser",
  "rewrites": [
    {
      "source": "/proxy-img/:id",
      "destination": "https://lh3.googleusercontent.com/d/:id"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
